# Optional production-style environment reference.
# The pure Docker script currently passes its own defaults directly to
# containers. Use these values as a checklist when adapting the deployment to a
# production server, Compose override file or CI/CD pipeline.

WEB_PORT=8080
API_PORT=8000
MYSQL_PORT=3306

MYSQL_DATABASE=resource_planning
MYSQL_USER=resource_planning
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-too

DATABASE_URL=mysql+pymysql://resource_planning:change-me@mysql:3306/resource_planning?charset=utf8mb4
APP_TIMEZONE=Asia/Shanghai
SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_MAX_AGE_SECONDS=604800
AVATAR_UPLOAD_MAX_BYTES=10485760

# Single-container local script defaults.
CONTAINER_NAME=resource-planning-single
DATA_VOLUME=resource-planning-single-data
IMAGE_NAME=resource-planning-all-in-one:latest
API_WORKERS=2
